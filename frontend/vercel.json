{
  "buildCommand": "npm run build -- --configuration production",
  "outputDirectory": "dist/ros/browser",
  "framework": null,
  "functions": {
    "api/ssr.js": {
      "includeFiles": "dist/ros/server/**"
    }
  },
  "routes": [
    {
      "src": "/cronjob_82482.html",
      "dest": "/cronjob_82482.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/(.*\\.(js|css|ico|png|jpg|svg|woff2?))",
      "dest": "/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/m/(.*)",
      "dest": "/api/ssr"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
